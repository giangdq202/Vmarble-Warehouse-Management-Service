DATABASE_URL=postgres://vmarble:vmarble@localhost:5433/vmarble?sslmode=disable
POSTGRES_HOST_PORT=5433
PORT=8080
LOG_LEVEL=debug
AUTH_SECRET=local-dev-secret-change-in-production

# Remnant auto-release: duration ALLOCATED before being reset to AVAILABLE
REMNANT_ALLOC_TIMEOUT=24h
# How often the background release task runs
REMNANT_ALLOC_CHECK_INTERVAL=1h
